---
---

<header>
  <nav>
    <a href="/" class="logo">SOUDAN</a>
    <ul>
      <li><a href="/configurator">仏壇シミュレーター</a></li>
      <li><a href="/access" class="contact-link">お問い合わせ</a></li>
    </ul>
    <a href="/contact" class="mobile-cta">相談する</a>
  </nav>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 24px 48px;
    background: linear-gradient(to bottom, rgba(8, 8, 20, 0.9), transparent);
    backdrop-filter: blur(4px);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
  }

  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    letter-spacing: 0.3em;
    color: #c9a84c;
    font-weight: 300;
  }

  ul {
    display: flex;
    gap: 40px;
    list-style: none;
  }

  ul a {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    color: #f5f0e8;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  ul a:hover {
    opacity: 1;
    color: #c9a84c;
  }

  .contact-link {
    border: 1px solid #c9a84c;
    padding: 8px 20px;
    color: #c9a84c !important;
    opacity: 1 !important;
    transition: background 0.2s !important;
  }

  .contact-link:hover {
    background: #c9a84c;
    color: #080814 !important;
  }

  .mobile-cta {
    display: none;
  }

  @media (max-width: 768px) {
    header {
      padding: 16px 20px;
    }
    ul {
      display: none;
    }
    .mobile-cta {
      display: inline-block;
      border: 1px solid #c9a84c;
      color: #c9a84c;
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      padding: 8px 18px;
    }
  }
</style>
