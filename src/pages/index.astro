---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout>
  <Header />

  <!-- 全シーンを重ねて配置 -->
  <div class="scenes">

    <!-- Scene 0: Hero -->
    <div class="scene active" data-scene="0">
      <canvas id="hero-canvas"></canvas>
      <div class="scene-content hero-content">
        <p class="hero-label">SOUDAN</p>
        <h1 class="hero-title">祈りを、<br />創る。</h1>
        <p class="hero-sub">あなたの想いをカタチに。</p>
      </div>
    </div>

    <!-- Scene 1: Concept -->
    <div class="scene" data-scene="1">
      <div class="scene-content">
        <p class="section-label">Concept</p>
        <h2 class="scene-title">SOUDANとは。</h2>
        <div class="divider"></div>
        <div class="sou-list">
          <div class="sou-item">
            <p class="sou-kanji">創</p>
            <p class="sou-desc">あなたとご家族だけのオリジナルのお仏壇。こだわりをぜひ職人と共に、あなたの手で創りだしてください。</p>
          </div>
          <div class="sou-item">
            <p class="sou-kanji">想</p>
            <p class="sou-desc">ご家族との思い出、好きだったものを今一度想像してみてください。</p>
          </div>
          <div class="sou-item">
            <p class="sou-kanji">添</p>
            <p class="sou-desc">不安に思われることがあれば、ご相談から。お仏壇をお部屋に置く最後まで、寄り添って対応いたします。</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Scene 2: Craftsmen -->
    <div class="scene craftsmen-scene" data-scene="2">
      <div class="scene-content">
        <p class="section-label">Craftsmen & Techniques</p>
        <h2 class="scene-title">職人と、技法。</h2>
        <div class="divider"></div>
        <div class="techniques-grid">
          <div class="technique-card">
            <h3>蒔絵</h3>
            <p>漆の上に金銀の粉を蒔いて描く、日本が誇る伝統装飾技法。繊細な文様があなたの想いを永遠に刻みます。</p>
          </div>
          <div class="technique-card">
            <h3>漆塗り</h3>
            <p>何十もの工程を経て積み重ねられる漆の層。深みのある艶と、百年を超える耐久性を持ちます。</p>
          </div>
          <div class="technique-card">
            <h3>彩色</h3>
            <p>岩絵具や金泥を用いた日本画の技法。仏の世界を彩る色彩が、祈りの空間に命を吹き込みます。</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Scene 3: Configurator CTA -->
    <div class="scene cfg-scene" data-scene="3">
      <div class="scene-content cfg-content">
        <p class="section-label">Try the Configurator</p>
        <h2 class="cfg-title">あなただけの仏壇を、<br />創ってみる。</h2>
        <p class="cfg-sub">色・技法・素材を自由に組み合わせて、<br />あなたの祈りの空間をイメージしてください。</p>
        <a href="/configurator" class="cfg-btn" id="cfg-link">3Dで試してみる →</a>
      </div>
    </div>


  </div><!-- /.scenes -->

  <!-- ナビゲーション -->
  <div class="scene-nav" id="nav-dots"></div>

  <!-- スプラッシュ -->
  <div id="splash">
    <p class="splash-label">SOUDAN</p>
  </div>

</Layout>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  // ── ヒーローカルーセル ──────────────────────────────────
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);

  const threeScene = new THREE.Scene();
  threeScene.background = new THREE.Color('#080814');
  threeScene.fog = new THREE.FogExp2('#080814', 0.07);

  const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);

  // ライト
  threeScene.add(new THREE.AmbientLight(0xffffff, 0.25));
  const dirLight = new THREE.DirectionalLight(0xffd4a0, 1.4);
  dirLight.position.set(3, 6, 4);
  threeScene.add(dirLight);
  const rimLight = new THREE.DirectionalLight(0x4060c0, 0.5);
  rimLight.position.set(-4, 2, -5);
  threeScene.add(rimLight);

  // カラープリセット [外枠/背板色, 扉色]
  const PRESETS: [string, string][] = [
    ['#0c0c0c', '#8b1a1a'],  // 漆黒 × 朱
    ['#1a3a6b', '#c9a84c'],  // 群青 × 金
    ['#5c1a2e', '#c9a84c'],  // 深緋 × 金
    ['#1a4a2e', '#c9a84c'],  // 常磐 × 金
    ['#8b5e1a', '#1a2a4a'],  // 飴色 × 藍鉄
    ['#1a2a4a', '#8b1a1a'],  // 藍鉄 × 朱
    ['#0d0d18', '#1a3a6b'],  // 黒 × 群青
  ];

  const COUNT = PRESETS.length;
  const getRadius = () => window.innerWidth < 768 ? 2.0 : 2.8;
  const carousel = new THREE.Group();
  threeScene.add(carousel);
  const clones: THREE.Object3D[] = [];

  function makeMat(hex: string) {
    return new THREE.MeshPhysicalMaterial({
      color: new THREE.Color(hex),
      roughness: 0.2,
      metalness: 0.05,
      clearcoat: 1.0,
      clearcoatRoughness: 0.15,
    });
  }

  new GLTFLoader().load('/altar.glb', (gltf) => {
    const source = gltf.scene;

    // GLB読み込み完了後にスプラッシュをフェードアウト
    setTimeout(() => {
      document.getElementById('splash')?.classList.add('done');
    }, 2000);

    for (let i = 0; i < COUNT; i++) {
      const [outerHex, doorHex] = PRESETS[i];
      const clone = source.clone(true);

      clone.traverse((node: any) => {
        if (!node.isMesh) return;
        const n: string = node.name.toLowerCase();
        node.material = (n.includes('door') || n.includes('curtain'))
          ? makeMat(doorHex)
          : makeMat(outerHex);
      });

      const angle = (i / COUNT) * Math.PI * 2;
      const r = getRadius();
      clone.position.set(Math.sin(angle) * r, 0, Math.cos(angle) * r);
      carousel.add(clone);
      clones.push(clone);
    }
  });

  function updateCamera() {
    const mobile = window.innerWidth < 768;
    camera.fov    = mobile ? 58 : 45;
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.position.set(0, mobile ? 0.8 : 1.6, mobile ? 4.2 : 5.5);
    camera.lookAt(0, mobile ? 0.1 : 0.3, 0);
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
    // カルーセル半径を更新
    const r = getRadius();
    clones.forEach((clone, i) => {
      const angle = (i / COUNT) * Math.PI * 2;
      clone.position.set(Math.sin(angle) * r, 0, Math.cos(angle) * r);
    });
  }
  updateCamera();
  window.addEventListener('resize', updateCamera);

  (function animate() {
    requestAnimationFrame(animate);
    carousel.rotation.y += 0.0016;
    // 各仏壇がカルーセルの回転を打ち消して常に正面を向く
    carousel.children.forEach(child => {
      child.rotation.y = Math.PI - carousel.rotation.y;
    });
    renderer.render(threeScene, camera);
  })();
</script>

<script>
  const scenes = document.querySelectorAll<HTMLElement>('.scene');
  const dotsContainer = document.getElementById('nav-dots')! as HTMLElement;
  const total = scenes.length;
  let current = 0;
  let animating = false;

  // ドット生成
  scenes.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = 'nav-dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('aria-label', `シーン ${i + 1}`);
    dot.addEventListener('click', e => { e.stopPropagation(); goTo(i); });
    dotsContainer.appendChild(dot);
  });

  function updateNav() {
    dotsContainer.querySelectorAll('.nav-dot').forEach((d, i) =>
      d.classList.toggle('active', i === current)
    );
  }

  function goTo(n: number) {
    if (animating || n === current || n < 0 || n >= total) return;
    animating = true;
    scenes[current].classList.remove('active');
    scenes[current].classList.add('leave');
    // フェードアウト完了後に次シーンをフェードイン
    setTimeout(() => {
      document.querySelectorAll('.scene.leave').forEach(s => s.classList.remove('leave'));
      current = n;
      scenes[current].classList.add('active');
      updateNav();
      setTimeout(() => { animating = false; }, 800);
    }, 500);
  }

  // タップ/クリックで次へ（フォーム・ボタン・リンクは除外）
  document.querySelector('.scenes')!.addEventListener('click', e => {
    const target = e.target as HTMLElement;
    if (target.closest('a, button, input, textarea, label, form')) return;
    goTo(current + 1);
  });

  // キーボード
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowDown' || e.key === 'ArrowRight') goTo(current + 1);
    if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') goTo(current - 1);
  });

  // スワイプ（横）
  let touchStartX = 0;
  document.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  document.addEventListener('touchend', e => {
    const dx = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(dx) < 50) return;
    if (dx > 0) goTo(current + 1);
    else goTo(current - 1);
  });


</script>

<style>
  /* ─── ベース ─── */
  :global(html), :global(body) {
    height: 100%;
    overflow: hidden;
  }

  .scenes {
    position: fixed;
    inset: 0;
  }

  /* ─── シーン ─── */
  .scene {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1.1s cubic-bezier(0.22,1,0.36,1);
    background: var(--color-bg);
  }
  .scene.active {
    opacity: 1;
    pointer-events: auto;
    z-index: 1;
  }
  .scene.leave {
    opacity: 0;
    z-index: 0;
  }

  .scene-content {
    max-width: 1000px;
    width: 100%;
    padding: 0 48px;
  }

  .scene-title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    margin-bottom: 0;
  }

  /* ─── Hero ─── */
  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .hero-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.9rem;
    letter-spacing: 0.5em;
    color: #c9a84c;
    margin-bottom: 24px;
  }
  .hero-title {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 300;
    letter-spacing: 0.15em;
    line-height: 1.3;
    margin-bottom: 24px;
  }
  .hero-sub {
    font-size: 1rem;
    letter-spacing: 0.3em;
    color: #8a8a9a;
  }

  /* ─── Concept ─── */
  .sou-list {
    width: 100%;
    max-width: 560px;
    margin-top: 36px;
  }
  .sou-item {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-bottom: 28px;
    opacity: 0;
  }
  .sou-item:last-child { margin-bottom: 0; }
  .scene.active .sou-item { animation: souFadeIn 1.2s ease forwards; }
  .scene.active .sou-item:nth-child(1) { animation-delay: 0.2s; }
  .scene.active .sou-item:nth-child(2) { animation-delay: 0.8s; }
  .scene.active .sou-item:nth-child(3) { animation-delay: 1.4s; }
  @keyframes souFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .sou-kanji {
    font-family: 'Cormorant Garamond', 'Noto Serif JP', serif;
    font-size: clamp(2.8rem, 5vw, 4rem);
    font-weight: 300;
    color: #c9a84c;
    line-height: 1;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    width: 1.2em;
  }
  .sou-desc {
    font-size: 0.88rem;
    line-height: 2;
    color: #d0cac0;
  }

  /* ─── Craftsmen ─── */
  .craftsmen-scene { background: #0d1628; }
  .techniques-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 8px;
  }
  .technique-card {
    border: 1px solid rgba(201,168,76,0.2);
    padding: 28px 24px;
  }
  .technique-card h3 {
    font-size: 1.1rem;
    letter-spacing: 0.15em;
    color: #c9a84c;
    margin-bottom: 12px;
  }
  .technique-card p { color: #d0cac0; line-height: 1.9; font-size: 0.85rem; }

  /* ─── Configurator CTA ─── */
  .cfg-scene {
    background: linear-gradient(135deg, #0a0f20 0%, #080814 60%, #0d1a2e 100%);
  }
  .cfg-content { text-align: center; }
  .cfg-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    line-height: 1.6;
    margin: 16px 0 24px;
  }
  .cfg-sub {
    font-size: 0.9rem;
    color: var(--color-muted);
    letter-spacing: 0.08em;
    line-height: 2;
    margin-bottom: 40px;
  }
  .cfg-btn {
    display: inline-block;
    border: 1px solid var(--color-gold);
    color: var(--color-gold);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    padding: 16px 48px;
    transition: all 0.3s;
  }
  .cfg-btn:hover { background: var(--color-gold); color: #080814; }


  /* ─── ナビゲーション ─── */
  .scene-nav {
    position: fixed;
    bottom: 32px;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
  }
  :global(.nav-dot) {
    width: 6px; height: 6px;
    border-radius: 3px;
    background: rgba(201,168,76,0.3);
    border: none; cursor: pointer;
    transition: all 0.4s cubic-bezier(0.22,1,0.36,1);
    padding: 0;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }
  :global(.nav-dot.active) {
    width: 22px;
    background: #c9a84c;
  }

  /* ─── スプラッシュ ─── */
  #splash {
    position: fixed;
    inset: 0;
    background: #080814;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 1;
    transition: opacity 1.4s ease;
  }
  #splash.done { opacity: 0; }
  .splash-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    letter-spacing: 0.65em;
    color: #c9a84c;
    opacity: 0;
    animation: splashIn 0.9s ease 0.2s forwards;
  }
  @keyframes splashIn {
    to { opacity: 1; }
  }

  /* ─── Mobile ─── */
  @media (max-width: 768px) {
    .sou-item { gap: 18px; margin-bottom: 20px; }
    .scene-content { padding: 0 20px; }
    .scene-nav { bottom: max(24px, calc(env(safe-area-inset-bottom, 0px) + 12px)); }
    .hero-title { letter-spacing: 0.08em; }
    .hero-sub { letter-spacing: 0.15em; font-size: 0.9rem; }
    .techniques-grid { grid-template-columns: 1fr; gap: 12px; overflow-y: auto; max-height: 60svh; }
    .technique-card { padding: 18px; }
  }
</style>
