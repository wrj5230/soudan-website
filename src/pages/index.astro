---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout>
  <Header />

  <!-- 全シーンを重ねて配置 -->
  <div class="scenes">

    <!-- Scene 0: Hero -->
    <div class="scene active" data-scene="0">
      <canvas id="hero-canvas"></canvas>
      <div class="scene-content hero-content">
        <p class="hero-label">SOUDAN</p>
        <h1 class="hero-title">祈りを、<br />創る。</h1>
        <p class="hero-sub">セミオーダーメイド仏壇で、あなたの想いをカタチに。</p>
      </div>
    </div>

    <!-- Scene 1: About -->
    <div class="scene" data-scene="1">
      <div class="scene-content about-content">
        <p class="section-label">About</p>
        <h2 class="scene-title">SOUDANとは</h2>
        <div class="divider"></div>

        <div class="about-visual">
          <div class="av-inputs">
            <div class="av-group">
              <p class="av-label">伝統技法</p>
              <div class="av-chips">
                <span class="av-chip av-chip-makie"></span>
                <span class="av-chip av-chip-rapto"></span>
              </div>
            </div>
            <span class="av-op av-op-x">×</span>
            <div class="av-group">
              <p class="av-label">こだわりのお色味</p>
              <div class="av-swatches">
                <span class="av-dot" style="background:#0c0c0c"></span>
                <span class="av-dot" style="background:#8b1a1a"></span>
                <span class="av-dot" style="background:#1e3a6e"></span>
                <span class="av-dot" style="background:#2e5e38"></span>
                <span class="av-dot" style="background:#4e3660"></span>
                <span class="av-dot" style="background:#c9a84c"></span>
              </div>
            </div>
          </div>
          <span class="av-op av-op-eq">=</span>
          <div class="av-group av-outcome">
            <p class="av-result">あなただけの<br class="av-br-mobile" />お仏壇</p>
          </div>
        </div>

        <p class="about-lead about-lead-caption">SOUDANは、大きさ・規格はそのままに、お仏壇の色味と加飾の技法を自由に選べる、セミオーダーメイドのサービスです。</p>
      </div>
    </div>

    <!-- Scene 2: Concept -->
    <div class="scene" data-scene="2">
      <div class="scene-content">
        <p class="section-label">Concept</p>
        <h2 class="scene-title">3つの<span class="sou-em">SOU</span></h2>
        <div class="divider"></div>
        <div class="sou-list">
          <div class="sou-item">
            <p class="sou-kanji">創</p>
            <p class="sou-desc">あなたとご家族だけのオリジナルのお仏壇。こだわりをぜひ職人と共に、あなたの手で創りだしてください。</p>
          </div>
          <div class="sou-item">
            <p class="sou-kanji">想</p>
            <p class="sou-desc">ご家族との思い出、好きだったものを今一度想像してみてください。</p>
          </div>
          <div class="sou-item">
            <p class="sou-kanji">添</p>
            <p class="sou-desc">不安に思われることがあれば、ご相談から。お仏壇をお部屋に置く最後まで、寄り添って対応いたします。</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Scene 3: Craftsmen -->
    <!-- Scene 3: 工程スライド -->
    <div class="scene craftsmen-scene" data-scene="3">
      <div class="scene-content">
        <p class="section-label">Process</p>
        <h2 class="scene-title">仏壇ができるまで</h2>
        <div class="divider"></div>
        <p class="ps-note">実際の製作工程は、ここでご紹介するよりもさらに細かく分かれています。</p>
        <div class="ps-list">
          <div class="ps-item">
            <img class="ps-bg" src="/images/kiji.png" alt="" onerror="this.style.display='none'"/>
            <div class="ps-content">
              <h3 class="ps-name">木地</h3>
              <p class="ps-read">きじ</p>
              <p class="ps-body">ヒノキやスギなど厳選された木材を、熟練の木地師が鑿と鉋で削り出します。木の呼吸を読みながら木取りをするのが職人の目利き。塗りや装飾の美しさはこの土台の精度にかかっています。</p>
            </div>
          </div>
          <div class="ps-item">
            <img class="ps-bg" src="/images/nuri.png" alt="" onerror="this.style.display='none'"/>
            <div class="ps-content">
              <h3 class="ps-name">塗</h3>
              <p class="ps-read">ぬり</p>
              <p class="ps-body">木地に漆を塗っては研ぎ、また塗っては研ぐ。この工程を何十回と繰り返すことで、深みのある艶と強度が生まれます。完成した漆面は百年以上の耐久性を持ちます。</p>
            </div>
          </div>
          <div class="ps-item">
            <img class="ps-bg" src="/images/soushoku.png" alt="" onerror="this.style.display='none'"/>
            <div class="ps-content">
              <h3 class="ps-name">装飾</h3>
              <p class="ps-read">そうしょく</p>
              <p class="ps-body">仕上がった塗面に、蒔絵や彩色など選ばれた技法で文様を施します。金銀の粉や岩絵具で描かれた文様が、祈りの空間に命を吹き込みます。</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scene 4–5: Store History -->
    <div class="scene history-scene" data-scene="4">
      <img class="history-bg" src="/images/tempo.jpg" alt="" />
      <div class="history-overlay"></div>
      <div class="scene-content history-content">
        <p class="section-label">Our Story</p>
        <h2 class="scene-title">当店について</h2>
        <div class="divider"></div>
        <p class="history-para">井上秀峰佛具店は、大正時代創業の京都の仏具店です。<br />100年にわたり、各宗派の寺院やご家庭に仏壇・仏具を届けてきました。<br />3代にわたって積み重ねてきた職人との信頼関係と知識をもとに、お客様だけのお仏壇製作をサポートさせていただきます。</p>
      </div>
    </div>

    <!-- Scene 5: Flow -->
    <div class="scene flow-scene" data-scene="5">
      <div class="scene-content">
        <p class="section-label">Flow</p>
        <h2 class="scene-title">ご利用の流れ</h2>
        <div class="divider"></div>
        <p class="flow-total">ご相談から納品まで、目安として約2〜3ヶ月程度です。</p>
        <p class="flow-price"><!-- TODO: 実際の価格帯に差し替え -->価格帯の目安　<strong>¥300,000〜</strong>　（技法により変動します。特注サイズもご相談いただけます）</p>
        <ol class="flow-list">
          <li class="flow-item">
            <div class="flow-left"><span class="flow-num">01</span></div>
            <div class="flow-text">
              <p class="flow-name">コンフィギュレーターで選ぶ</p>
              <p class="flow-desc">色・技法をシミュレーションしながら、イメージを形にします。</p>
            </div>
          </li>
          <li class="flow-item">
            <div class="flow-left"><span class="flow-num">02</span><span class="flow-time">1〜2週間</span></div>
            <div class="flow-text">
              <p class="flow-name">ご相談</p>
              <p class="flow-desc">オンラインにて、イメージをもとに詳細をヒアリングし、お見積もりをご提示します。</p>
            </div>
          </li>
          <li class="flow-item">
            <div class="flow-left"><span class="flow-num">03</span><span class="flow-time">約2〜3ヶ月</span></div>
            <div class="flow-text">
              <p class="flow-name">制作</p>
              <p class="flow-desc">職人が一点ずつ丁寧に製作します。</p>
            </div>
          </li>
          <li class="flow-item">
            <div class="flow-left"><span class="flow-num">04</span><span class="flow-time">1〜2週間</span></div>
            <div class="flow-text">
              <p class="flow-name">納品</p>
              <p class="flow-desc">基本的には郵送にてお届けします。</p>
            </div>
          </li>
          <li class="flow-item">
            <div class="flow-left"><span class="flow-num">05</span></div>
            <div class="flow-text">
              <p class="flow-name">アフターサポート</p>
              <p class="flow-desc">設置場所や仏具の配置など、不安なことがあればお気軽にご相談ください。</p>
            </div>
          </li>
        </ol>
      </div>
    </div>

    <!-- Scene 6: Configurator CTA -->
    <div class="scene cfg-scene" data-scene="6">
      <div class="scene-content cfg-content">
        <p class="section-label">Try the Configurator</p>
        <h2 class="cfg-title">あなただけの仏壇を、<br />創ってみる。</h2>
        <p class="cfg-sub">3Dモデルを回転させながら、<br />色・技法の組み合わせをリアルタイムに確かめられます。</p>
        <a href="/configurator" class="cfg-btn" id="cfg-link">3Dで試してみる →</a>
      </div>
    </div>


  </div><!-- /.scenes -->

  <!-- ナビゲーション -->
  <div class="scene-nav" id="nav-dots"></div>

  <!-- スプラッシュ -->
  <div id="splash">
    <p class="splash-label">SOUDAN</p>
  </div>

</Layout>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  // ── ヒーローカルーセル ──────────────────────────────────
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);

  const threeScene = new THREE.Scene();
  threeScene.background = new THREE.Color('#080814');
  threeScene.fog = new THREE.FogExp2('#080814', 0.07);

  const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);

  // ライト
  threeScene.add(new THREE.AmbientLight(0xffffff, 0.25));
  const dirLight = new THREE.DirectionalLight(0xffd4a0, 1.4);
  dirLight.position.set(3, 6, 4);
  threeScene.add(dirLight);
  const rimLight = new THREE.DirectionalLight(0x4060c0, 0.5);
  rimLight.position.set(-4, 2, -5);
  threeScene.add(rimLight);

  // カラープリセット [外枠/背板色, 扉色]
  const PRESETS: [string, string][] = [
    ['#0c0c0c', '#8b1a1a'],  // 漆黒 × 朱
    ['#1a3a6b', '#c9a84c'],  // 群青 × 金
    ['#5c1a2e', '#c9a84c'],  // 深緋 × 金
    ['#1a4a2e', '#c9a84c'],  // 常磐 × 金
    ['#8b5e1a', '#1a2a4a'],  // 飴色 × 藍鉄
    ['#1a2a4a', '#8b1a1a'],  // 藍鉄 × 朱
    ['#0d0d18', '#1a3a6b'],  // 黒 × 群青
  ];

  const COUNT = PRESETS.length;
  const getRadius = () => window.innerWidth < 768 ? 2.0 : 2.8;
  const carousel = new THREE.Group();
  threeScene.add(carousel);
  const clones: THREE.Object3D[] = [];

  function makeMat(hex: string) {
    return new THREE.MeshPhysicalMaterial({
      color: new THREE.Color(hex),
      roughness: 0.2,
      metalness: 0.05,
      clearcoat: 1.0,
      clearcoatRoughness: 0.15,
    });
  }

  new GLTFLoader().load('/altar.glb', (gltf) => {
    const source = gltf.scene;

    // GLB読み込み完了後にスプラッシュをフェードアウト
    setTimeout(() => {
      document.getElementById('splash')?.classList.add('done');
    }, 2000);

    for (let i = 0; i < COUNT; i++) {
      const [outerHex, doorHex] = PRESETS[i];
      const clone = source.clone(true);

      clone.traverse((node: any) => {
        if (!node.isMesh) return;
        const n: string = node.name.toLowerCase();
        node.material = (n.includes('door') || n.includes('curtain'))
          ? makeMat(doorHex)
          : makeMat(outerHex);
      });

      const angle = (i / COUNT) * Math.PI * 2;
      const r = getRadius();
      clone.position.set(Math.sin(angle) * r, 0, Math.cos(angle) * r);
      carousel.add(clone);
      clones.push(clone);
    }
  });

  function updateCamera() {
    const mobile = window.innerWidth < 768;
    camera.fov    = mobile ? 58 : 45;
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.position.set(0, mobile ? 0.8 : 1.6, mobile ? 4.2 : 5.5);
    camera.lookAt(0, mobile ? 0.1 : 0.3, 0);
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
    // カルーセル半径を更新
    const r = getRadius();
    clones.forEach((clone, i) => {
      const angle = (i / COUNT) * Math.PI * 2;
      clone.position.set(Math.sin(angle) * r, 0, Math.cos(angle) * r);
    });
  }
  updateCamera();
  window.addEventListener('resize', updateCamera);

  (function animate() {
    requestAnimationFrame(animate);
    carousel.rotation.y += 0.0016;
    // 各仏壇がカルーセルの回転を打ち消して常に正面を向く
    carousel.children.forEach(child => {
      child.rotation.y = Math.PI - carousel.rotation.y;
    });
    renderer.render(threeScene, camera);
  })();
</script>

<script>
  const scenes = document.querySelectorAll<HTMLElement>('.scene');
  const dotsContainer = document.getElementById('nav-dots')! as HTMLElement;
  const total = scenes.length;
  let current = 0;
  let animating = false;

  // ドット生成
  scenes.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = 'nav-dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('aria-label', `シーン ${i + 1}`);
    dot.addEventListener('click', e => { e.stopPropagation(); goTo(i); });
    dotsContainer.appendChild(dot);
  });

  function updateNav() {
    dotsContainer.querySelectorAll('.nav-dot').forEach((d, i) =>
      d.classList.toggle('active', i === current)
    );
  }

  function goTo(n: number) {
    if (animating || n === current || n < 0 || n >= total) return;
    animating = true;
    scenes[current].classList.remove('active');
    scenes[current].classList.add('leave');
    setTimeout(() => {
      document.querySelectorAll('.scene.leave').forEach(s => s.classList.remove('leave'));
      current = n;
      scenes[current].classList.add('active');
      updateNav();
      setTimeout(() => { animating = false; }, 800);
    }, 500);
  }

  // タップ/クリックで次へ（フォーム・ボタン・リンクは除外）
  document.querySelector('.scenes')!.addEventListener('click', e => {
    const target = e.target as HTMLElement;
    if (target.closest('a, button, input, textarea, label, form')) return;
    goTo(current + 1);
  });

  // キーボード
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowDown' || e.key === 'ArrowRight') goTo(current + 1);
    if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') goTo(current - 1);
  });

  // スワイプ（横）
  let touchStartX = 0;
  document.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  document.addEventListener('touchend', e => {
    const dx = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(dx) < 50) return;
    if (dx > 0) goTo(current + 1);
    else goTo(current - 1);
  });

  // 縦スクロールは横スワイプと干渉しないためJS不要

</script>

<style>
  /* ─── ベース ─── */
  :global(html), :global(body) {
    height: 100%;
    overflow: hidden;
  }

  .scenes {
    position: fixed;
    inset: 0;
  }

  /* ─── シーン ─── */
  .scene {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1.1s cubic-bezier(0.22,1,0.36,1);
    background: var(--color-bg);
  }
  .scene.active {
    opacity: 1;
    pointer-events: auto;
    z-index: 1;
  }
  .scene.leave {
    opacity: 0;
    z-index: 0;
  }

  .scene-content {
    max-width: 1000px;
    width: 100%;
    padding: 0 48px;
  }

  .scene-title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    margin-bottom: 0;
  }
  .sou-em {
    font-family: 'Cormorant Garamond', serif;
    color: #c9a84c;
    letter-spacing: 0.5em;
    font-style: normal;
  }

  /* ─── Hero ─── */
  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .hero-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.9rem;
    letter-spacing: 0.5em;
    color: #c9a84c;
    margin-bottom: 24px;
  }
  .hero-title {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 300;
    letter-spacing: 0.15em;
    line-height: 1.3;
    margin-bottom: 24px;
  }
  .hero-sub {
    font-size: 1rem;
    letter-spacing: 0.3em;
    color: #8a8a9a;
  }

  /* ─── Concept ─── */
  .sou-list {
    width: 100%;
    max-width: 560px;
    margin-top: 36px;
  }
  .sou-item {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-bottom: 28px;
    opacity: 0;
  }
  .sou-item:last-child { margin-bottom: 0; }
  .scene.active .sou-item { animation: souFadeIn 1.2s ease forwards; }
  .scene.active .sou-item:nth-child(1) { animation-delay: 0.2s; }
  .scene.active .sou-item:nth-child(2) { animation-delay: 0.8s; }
  .scene.active .sou-item:nth-child(3) { animation-delay: 1.4s; }
  @keyframes souFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .sou-kanji {
    font-family: 'Cormorant Garamond', 'Noto Serif JP', serif;
    font-size: clamp(3.5rem, 6vw, 5rem);
    font-weight: 300;
    color: #c9a84c;
    line-height: 1;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    width: 1.1em;
    text-shadow: 0 0 24px rgba(201,168,76,0.3);
  }
  .sou-desc {
    font-size: 0.88rem;
    line-height: 2;
    color: #d0cac0;
  }

  /* ─── About ─── */
  .about-content {
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
  }
  .about-content > .section-label,
  .about-content > .scene-title,
  .about-content > .divider {
    text-align: left;
    margin-left: 0;
    margin-right: auto;
  }
  .about-lead-caption {
    font-size: 0.85rem;
    line-height: 1.9;
    letter-spacing: 0.04em;
    color: #8a8a9a;
  }

  /* ─── About Visual（伝統技法×こだわりのお色味＝あなただけのお仏壇） ─── */
  .about-visual {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    flex-wrap: wrap;
    gap: 36px;
    margin: 12px 0 40px;
    padding: 44px 56px;
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 6px;
    background: rgba(201,168,76,0.03);
  }
  .av-inputs {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    flex-wrap: wrap;
    gap: 36px;
  }
  .av-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .av-inputs, .av-op-eq, .av-outcome { opacity: 0; }
  .scene.active .av-inputs,
  .scene.active .av-op-eq,
  .scene.active .av-outcome { animation: souFadeIn 1s ease forwards; }
  .scene.active .av-inputs   { animation-delay: 0.2s; }
  .scene.active .av-op-eq    { animation-delay: 0.7s; }
  .scene.active .av-outcome  { animation-delay: 1.0s; }
  .av-label {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.78rem;
    letter-spacing: 0.25em;
    color: rgba(201,168,76,0.6);
  }
  .av-swatches { display: flex; }
  .av-dot {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid rgba(245,240,232,0.25);
    box-shadow: 0 4px 14px rgba(0,0,0,0.4);
    margin-left: -16px;
  }
  .av-dot:first-child { margin-left: 0; }
  .av-op {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.4rem;
    font-weight: 300;
    color: rgba(201,168,76,0.6);
    flex-shrink: 0;
    padding-bottom: 6px;
  }
  /* ×と＝はラベル分だけ下にずらし、パレット（60px行）の高さに合わせて中央揃え */
  .av-op-x,
  .av-op-eq {
    padding-bottom: 0;
    margin-top: 31px;
    height: 60px;
    display: flex;
    align-items: center;
  }
  .av-chips { display: flex; gap: 14px; }
  .av-chip {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    border: 1px solid rgba(245,240,232,0.25);
    box-shadow: 0 4px 14px rgba(0,0,0,0.4);
  }
  .av-chip-makie {
    background: linear-gradient(135deg, #8a6d1e 0%, #c9a84c 45%, #e8c96a 55%, #8a6d1e 100%);
