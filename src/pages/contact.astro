---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="お問い合わせ | SOUDAN" description="SOUDANへのお問い合わせ・ご相談はこちらから。">
  <Header />

  <main>
    <div class="contact-wrap">
      <p class="section-label">Contact</p>
      <h1 class="page-title">ご相談はこちら。</h1>
      <div class="divider"></div>
      <p class="lead">まずはお気軽にご連絡ください。<br />内容を確認のうえ、担当者よりご連絡いたします。</p>

      <!-- コンフィギュレーター設定サマリー（URLパラメータがある場合のみ表示） -->
      <div class="config-summary" id="config-summary" style="display:none">
        <p class="config-summary-label">選択されたイメージ</p>
        <ul class="config-list" id="config-list"></ul>
        <p class="config-summary-note">※ 詳細はご相談にてお伺いします</p>
      </div>

      <form class="contact-form" id="contact-form" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="name">お名前 <span class="required">*</span></label>
            <input type="text" id="name" name="name" autocomplete="name" required />
          </div>
          <div class="form-group">
            <label for="email">メールアドレス <span class="required">*</span></label>
            <input type="email" id="email" name="email" autocomplete="email" required />
          </div>
        </div>
        <div class="form-group">
          <label for="phone">電話番号</label>
          <input type="tel" id="phone" name="phone" autocomplete="tel" />
        </div>
        <div class="survey-divider">
          <span class="survey-divider-label">お仏壇についてお聞かせください</span>
        </div>
        <div class="form-group">
          <label for="for-whom">どなたのためのお仏壇ですか？</label>
          <select id="for-whom" name="for-whom">
            <option value="">選択してください</option>
            <option value="父">父</option>
            <option value="母">母</option>
            <option value="祖父">祖父</option>
            <option value="祖母">祖母</option>
            <option value="配偶者">配偶者</option>
            <option value="子">子</option>
            <option value="その他">その他</option>
          </select>
        </div>
        <div class="form-group">
          <label for="why-custom">なぜSOUDANを選ばれましたか？</label>
          <textarea id="why-custom" name="why-custom" rows="3"></textarea>
        </div>
        <div class="form-group">
          <label for="design-story">このデザインにはどのようなこだわりを込められましたか？</label>
          <textarea id="design-story" name="design-story" rows="3"></textarea>
        </div>
        <div class="form-group">
          <label for="message">その他ご要望</label>
          <textarea id="message" name="message" rows="4"></textarea>
        </div>
        <button type="submit" id="submit-btn">送信する</button>
      </form>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const form      = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

const TECH_NAMES: Record<string, string> = {
    none: 'なし', makie: '蒔絵', raptopaint: 'ラップ塗り', raden: '螺鈿',
  };
  const PART_LABELS: Record<string, string> = {
    outer: '外枠・台', 'door-front': '扉（表）', 'door-back': '扉（裏）',
    back: '背板', curtain: '垂れ幕',
  };

  const params = new URLSearchParams(window.location.search);
  const configParam = params.get('config');
  let configData: any = null;
  if (configParam) {
    try {
      configData = JSON.parse(configParam);
    } catch (e) {
      // ignore malformed config param
    }
  }

  if (configData?.colors) {
    const summary = document.getElementById('config-summary');
    const list    = document.getElementById('config-list');
    if (summary && list) {
      summary.style.display = 'block';
      for (const [part, label] of Object.entries(PART_LABELS)) {
        const hex  = String(configData.colors[part] ?? '');
        const tech = String(configData.techniques?.[part] ?? 'none');
        const techName = TECH_NAMES[tech] ?? tech;

        const li = document.createElement('li');
        li.className = 'config-item';

        const swatch = document.createElement('span');
        swatch.className = 'config-swatch';
        swatch.style.backgroundColor = hex;

        const partEl = document.createElement('span');
        partEl.className = 'config-part';
        partEl.textContent = label;

        li.appendChild(swatch);
        li.appendChild(partEl);

        if (tech !== 'none') {
          const techEl = document.createElement('span');
          techEl.className = 'config-tech';
          techEl.textContent = techName;
          li.appendChild(techEl);
        }

        list.appendChild(li);
      }
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    submitBtn.textContent = '送信中...';
    submitBtn.disabled = true;

    const survey = {
      forWhom:     (document.getElementById('for-whom')     as HTMLSelectElement).value   || null,
      whyCustom:   (document.getElementById('why-custom')   as HTMLTextAreaElement).value || null,
      designStory: (document.getElementById('design-story') as HTMLTextAreaElement).value || null,
    };

    const { error } = await supabase.from('contacts').insert({
      name:    (document.getElementById('name')    as HTMLInputElement).value,
      email:   (document.getElementById('email')   as HTMLInputElement).value,
      phone:   (document.getElementById('phone')   as HTMLInputElement).value || null,
      message: (document.getElementById('message') as HTMLTextAreaElement).value || null,
      config:  configData,
      survey,
    });

    if (error) {
      submitBtn.textContent = '送信する';
      submitBtn.disabled = false;
      alert('送信に失敗しました。しばらく経ってから再度お試しください。');
      return;
    }

    window.location.href = '/thanks';
  });
</script>

<style>
  main {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
  }

  .contact-wrap {
    max-width: 640px;
    width: 100%;
  }

  .page-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 300;
    letter-spacing: 0.1em;
    margin-bottom: 0;
  }

  .divider {
    width: 40px;
    height: 1px;
    background: #c9a84c;
    margin: 24px 0;
  }

  .lead {
    font-size: 0.9rem;
    color: #8a8a9a;
    line-height: 2;
    letter-spacing: 0.05em;
    margin-bottom: 48px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  /* ─── Config Summary ─── */
  .config-summary {
    border: 1px solid rgba(201,168,76,0.25);
    padding: 24px 28px;
    margin-bottom: 36px;
  }
  .config-summary-label {
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    color: rgba(201,168,76,0.85);
    margin-bottom: 18px;
  }
  .config-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  /* JS生成要素は :global() でスコープを外す */
  :global(.config-item) { display: flex; align-items: center; gap: 16px; }
  :global(.config-swatch) {
    display: block;
    width: 32px; height: 32px; border-radius: 2px;
    flex-shrink: 0; border: 1px solid rgba(255,255,255,0.15);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.4);
  }
  :global(.config-part) {
    font-size: 0.9rem; letter-spacing: 0.08em; color: #8a8a9a;
    width: 90px; flex-shrink: 0;
  }
  :global(.config-tech) {
    font-size: 0.85rem; letter-spacing: 0.1em;
    color: rgba(201,168,76,0.65);
  }
  .config-summary-note {
    font-size: 0.7rem; color: #5a5a6a; margin-top: 16px; letter-spacing: 0.05em;
  }

  .survey-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 8px 0 4px;
  }
  .survey-divider::before,
  .survey-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(201,168,76,0.15);
  }
  .survey-divider-label {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    color: rgba(201,168,76,0.5);
    white-space: nowrap;
  }

  select {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(201,168,76,0.25);
    color: #f5f0e8;
    font-family: 'Noto Serif JP', serif;
    font-size: 1rem;
    font-weight: 300;
    padding: 10px 0;
    outline: none;
    width: 100%;
    cursor: pointer;
  }
  select option { background: #0d0d1a; }
  select:focus { border-bottom-color: #c9a84c; }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #8a8a9a;
  }

  .required { color: #c9a84c; }

  input, textarea {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(201,168,76,0.25);
    color: #f5f0e8;
    font-family: 'Noto Serif JP', serif;
    font-size: 1rem;
    font-weight: 300;
    padding: 10px 0;
    outline: none;
    transition: border-color 0.3s;
    width: 100%;
  }

  input:focus, textarea:focus {
    border-bottom-color: #c9a84c;
  }

  textarea { resize: none; }

  button[type="submit"] {
    align-self: flex-start;
    background: transparent;
    border: 1px solid #c9a84c;
    color: #c9a84c;
    cursor: pointer;
    font-family: 'Noto Serif JP', serif;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    padding: 14px 48px;
    transition: all 0.3s;
    margin-top: 8px;
  }

  button[type="submit"]:hover:not(:disabled) {
    background: #c9a84c;
    color: #080814;
  }

  button[type="submit"]:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .success-msg {
    text-align: center;
    padding: 48px 0;
  }

  .success-icon {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: #c9a84c;
    margin-bottom: 24px;
  }

  .success-title {
    font-size: 1.2rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    margin-bottom: 12px;
  }

  .success-sub {
    font-size: 0.85rem;
    color: #8a8a9a;
    letter-spacing: 0.08em;
    line-height: 2;
  }

  @media (max-width: 768px) {
    main { padding: 100px 20px 60px; align-items: flex-start; }
    .form-row { grid-template-columns: 1fr; }
    button[type="submit"] { width: 100%; text-align: center; }
  }
</style>
