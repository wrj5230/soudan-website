---
import Layout from '../../layouts/Layout.astro';
import ConsultNav from '../../components/ConsultNav.astro';
---

<Layout title="会社紹介 | SOUDAN 商談">
  <ConsultNav currentPage="company" />

  <main class="page-main">
    <div class="page-wrap">

      <!-- ブランドヘッダー -->
      <div class="brand-header">
        <h1 class="brand-catch">あなたの想いを、かたちに。</h1>
      </div>

      <div class="section-divider"></div>

      <!-- 代表者一言 -->
      <section class="message-section">
        <p class="section-eyebrow">代表より</p>
        <blockquote class="message-quote">
          <!-- TODO: 代表者メッセージを差し替え -->
          「お仏壇は、祈りの場であり、家族の歴史を刻む場所でもあります。
          SOUDANでは、お客様お一人おひとりのストーリーに寄り添いながら、
          想いを込めたお仏壇をご一緒に作らせていただきます。」
        </blockquote>
        <p class="message-author">三代目当主　井上浩司</p>
      </section>

      <!-- Instagram リンク -->
      <div class="sns-row">
        <a href="https://www.instagram.com/inoue_shuho/" target="_blank" rel="noopener" class="sns-link">
          Instagram で事例を見る →
        </a>
      </div>

    </div>
  </main>
</Layout>

<script>
  if (sessionStorage.getItem('consult_auth') !== 'ok') {
    const id = new URLSearchParams(location.search).get('id');
    location.href = `/consult${id ? '?id=' + id : ''}`;
  }
</script>

<style>
  .page-main {
    min-height: 100vh;
    padding: 88px 24px 80px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  .page-wrap {
    max-width: 760px;
    width: 100%;
  }

  /* ブランドヘッダー */
  .brand-header { text-align: center; padding: 40px 0; }
  .brand-catch {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 300;
    letter-spacing: 0.12em;
    line-height: 1.6;
  }

  .section-divider {
    height: 1px;
    background: rgba(201,168,76,0.12);
    margin: 48px 0;
  }

  /* 代表メッセージ */
  .message-section { margin-bottom: 16px; }
  .message-quote {
    font-size: 0.95rem;
    line-height: 2.0;
    color: #c0bab0;
    letter-spacing: 0.06em;
    border-left: 2px solid rgba(201,168,76,0.3);
    padding-left: 24px;
    margin-bottom: 16px;
    font-style: normal;
  }
  .message-author {
    font-size: 0.75rem;
    color: #6a6a7a;
    letter-spacing: 0.15em;
    padding-left: 24px;
  }

  /* SNS */
  .sns-row { margin-top: 48px; text-align: center; }
  .sns-link {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    color: rgba(201,168,76,0.7);
    text-decoration: none;
    border-bottom: 1px solid rgba(201,168,76,0.3);
    padding-bottom: 2px;
    transition: color 0.2s;
  }
  .sns-link:hover { color: #c9a84c; }
</style>
