---
import Layout from '../../layouts/Layout.astro';
import ConsultNav from '../../components/ConsultNav.astro';
---

<Layout title="イントロ | SOUDAN 商談">
  <ConsultNav currentPage="intro" />

  <main class="page-main">
    <div class="page-wrap">

      <div class="agenda-block">
        <p class="agenda-eyebrow">本日の流れ</p>
        <ol class="agenda-list">
          <li class="agenda-item no-desc">
            <span class="agenda-num">01</span>
            <div class="agenda-body">
              <p class="agenda-title">お見積りのご説明</p>
            </div>
          </li>
          <li class="agenda-item no-desc">
            <span class="agenda-num">02</span>
            <div class="agenda-body">
              <p class="agenda-title">SOUDANについて</p>
            </div>
          </li>
          <li class="agenda-item">
            <span class="agenda-num">03</span>
            <div class="agenda-body">
              <p class="agenda-title">職人紹介</p>
              <p class="agenda-desc">製作に携わる職人をご紹介します。</p>
            </div>
          </li>
          <li class="agenda-item">
            <span class="agenda-num">04</span>
            <div class="agenda-body">
              <p class="agenda-title">デザインの確認</p>
              <p class="agenda-desc">選んでいただいたイメージを3Dで一緒に確認します</p>
            </div>
          </li>
          <li class="agenda-item no-desc">
            <span class="agenda-num">05</span>
            <div class="agenda-body">
              <p class="agenda-title">今後の流れについて</p>
            </div>
          </li>
        </ol>
      </div>

      <p class="duration-note">所要時間の目安：約 30〜45 分</p>

    </div>
  </main>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    const id = new URLSearchParams(location.search).get('id');
    location.href = `/consult${id ? '?id=' + id : ''}`;
  }
</script>

<style>
  .page-main {
    min-height: 100vh;
    padding: 52px 24px 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .page-wrap { max-width: 720px; width: 100%; }

  /* アジェンダ */
  .agenda-block { margin-bottom: 48px; padding-top: 40px; }
  .agenda-eyebrow {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.4em;
    color: #c9a84c;
    margin-bottom: 40px;
    text-align: center;
  }
  .agenda-list { list-style: none; display: flex; flex-direction: column; }
  .agenda-item {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(201,168,76,0.08);
    align-items: center;
  }
  .agenda-item:first-child { border-top: 1px solid rgba(201,168,76,0.08); }
  .agenda-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: rgba(201,168,76,0.25);
    line-height: 1;
  }
  .agenda-title {
    font-size: 1.1rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    margin-bottom: 6px;
  }
  .agenda-item.no-desc .agenda-title { margin-bottom: 0; }
  .agenda-desc {
    font-size: 0.78rem;
    color: #6a6a7a;
    letter-spacing: 0.06em;
    line-height: 1.8;
  }

  .duration-note {
    text-align: center;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: #5a5a6a;
  }
</style>
