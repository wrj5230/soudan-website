---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="送信完了 | SOUDAN" description="お問い合わせを受け付けました。">
  <Header />

  <main>
    <div class="thanks-wrap">
      <p class="mark">—</p>
      <h1 class="title">ありがとうございます。</h1>
      <div class="divider"></div>
      <p class="body-text">
        お問い合わせを受け付けました。<br />
        内容を確認のうえ、担当者よりご連絡いたします。<br />
        今しばらくお待ちください。
      </p>
      <a href="/" class="btn-home">トップへ戻る</a>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  main {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 80px;
  }

  .thanks-wrap {
    max-width: 560px;
    width: 100%;
    text-align: center;
    animation: fadeUp 1s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .mark {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: #c9a84c;
    margin-bottom: 32px;
    letter-spacing: 0.3em;
  }

  .title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 300;
    letter-spacing: 0.15em;
    margin-bottom: 0;
  }

  .divider {
    width: 40px;
    height: 1px;
    background: #c9a84c;
    margin: 28px auto;
  }

  .body-text {
    font-size: 0.9rem;
    color: #8a8a9a;
    line-height: 2.4;
    letter-spacing: 0.08em;
    margin-bottom: 56px;
  }

  .btn-home {
    display: inline-block;
    border: 1px solid rgba(201, 168, 76, 0.5);
    color: #c9a84c;
    font-family: 'Noto Serif JP', serif;
    font-size: 0.8rem;
    letter-spacing: 0.25em;
    padding: 14px 48px;
    text-decoration: none;
    transition: all 0.3s;
  }

  .btn-home:hover {
    background: #c9a84c;
    color: #080814;
    border-color: #c9a84c;
  }

  @media (max-width: 768px) {
    main { padding: 100px 20px 60px; }
    .btn-home { width: 100%; text-align: center; display: block; }
  }
</style>
